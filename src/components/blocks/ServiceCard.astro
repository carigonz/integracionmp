---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  excerpt: string;
  icon: string;
  href: string;
}

const { title, excerpt, icon, href } = Astro.props;
---

<a
  href={href}
  class="block bg-white rounded-2xl p-7 border border-neutral-100 shadow-soft hover:shadow-lift hover:-translate-y-1.5 transition-all duration-300 group"
>
  <div class="bg-gradient-to-br from-primary-500 to-primary-700 text-white rounded-xl p-3 w-fit shadow-soft group-hover:scale-110 transition-transform duration-300">
    <Icon name={icon} class="size-6" />
  </div>

  <h3 class="text-xl font-semibold mt-5 group-hover:text-primary-600 transition-colors">
    {title}
  </h3>

  <p class="text-neutral-600 text-sm mt-2 leading-relaxed text-justify">
    {excerpt}
  </p>

  <span class="inline-flex items-center gap-1 text-primary-600 font-medium text-sm mt-5 group-hover:gap-2 transition-all">
    Más información <span aria-hidden="true">&rarr;</span>
  </span>
</a>
