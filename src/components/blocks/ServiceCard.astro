---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  excerpt: string;
  icon: string;
  href: string;
}

const { title, excerpt, icon, href } = Astro.props;
---

<a
  href={href}
  class="block bg-white rounded-xl p-6 border border-neutral-200 hover:shadow-lg hover:border-primary-200 transition-all group"
>
  <div class="bg-primary-100 text-primary-600 rounded-lg p-3 w-fit">
    <Icon name={icon} class="size-6" />
  </div>

  <h3 class="text-xl font-semibold mt-4 group-hover:text-primary-600 transition-colors">
    {title}
  </h3>

  <p class="text-neutral-600 text-sm mt-2">
    {excerpt}
  </p>

  <span class="inline-block text-primary-600 font-medium text-sm mt-4">
    Más información &rarr;
  </span>
</a>
