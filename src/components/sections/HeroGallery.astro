---
// Galeria de cuadrados de obra (2 columnas) que rotan solos al lado del retrato.
// Al hacer clic, se abre un visor ampliado con navegacion entre las 12 fotos.
const COUNT = 12;
const images = Array.from(
  { length: COUNT },
  (_, i) => `/hero/hero-${String(i + 1).padStart(2, '0')}.jpg`
);
const SLOTS = 8;
const initial = images.slice(0, SLOTS);
---

<div
  id="hero-gallery"
  class="grid grid-cols-2 gap-2.5 flex-[2] self-stretch content-between"
  data-count={COUNT}
>
  {
    initial.map((src, i) => (
      <button
        type="button"
        class="hero-thumb-btn relative aspect-square overflow-hidden rounded-xl ring-1 ring-white/15 shadow-lg cursor-pointer group"
        aria-label="Ampliar foto de trabajo"
      >
        <img
          src={src}
          alt="Trabajo realizado por IntegracionMP"
          loading="lazy"
          data-slot={i}
          class="hero-thumb absolute inset-0 h-full w-full object-cover transition-all duration-700 group-hover:scale-110"
        />
        <span class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors" aria-hidden="true"></span>
      </button>
    ))
  }
</div>

<!-- Visor ampliado (lightbox) -->
<div
  id="hero-lightbox"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/85 backdrop-blur-sm p-4"
  role="dialog"
  aria-modal="true"
  aria-label="Foto de trabajo ampliada"
>
  <button id="lb-close" type="button" class="absolute top-4 right-4 text-white/80 hover:text-white text-3xl leading-none size-11 rounded-full bg-white/10 hover:bg-white/20 transition-colors" aria-label="Cerrar">&times;</button>
  <button id="lb-prev" type="button" class="absolute left-3 sm:left-6 text-white/80 hover:text-white text-4xl leading-none size-12 rounded-full bg-white/10 hover:bg-white/20 transition-colors" aria-label="Anterior">&lsaquo;</button>
  <img id="lb-img" src="" alt="Trabajo realizado por IntegracionMP" class="max-h-[70vh] max-w-[88vw] sm:max-w-md rounded-2xl shadow-2xl object-contain" />
  <button id="lb-next" type="button" class="absolute right-3 sm:right-6 text-white/80 hover:text-white text-4xl leading-none size-12 rounded-full bg-white/10 hover:bg-white/20 transition-colors" aria-label="Siguiente">&rsaquo;</button>
</div>

<script>
  const gallery = document.getElementById('hero-gallery');
  const lightbox = document.getElementById('hero-lightbox');
  const lbImg = document.getElementById('lb-img') as HTMLImageElement | null;

  if (gallery && lightbox && lbImg) {
    const count = parseInt(gallery.dataset.count || '12', 10);
    const thumbsSrc = Array.from(
      { length: count },
      (_, i) => `/hero/hero-${String(i + 1).padStart(2, '0')}.jpg`
    );
    const fullSrc = Array.from(
      { length: count },
      (_, i) => `/hero/full/hero-${String(i + 1).padStart(2, '0')}.jpg`
    );

    const buttons = Array.from(
      gallery.querySelectorAll<HTMLButtonElement>('.hero-thumb-btn')
    );
    const thumbs = buttons.map(
      (b) => b.querySelector('img') as HTMLImageElement
    );
    const current = thumbs.map((t) => t.getAttribute('src') || '');

    // ---- Rotacion escalonada de miniaturas ----
    thumbsSrc.forEach((src) => {
      const img = new Image();
      img.src = src;
    });

    let paused = false;
    function swap() {
      if (paused) return;
      const slot = Math.floor(Math.random() * thumbs.length);
      const visible = new Set(current);
      const candidates = thumbsSrc.filter((s) => !visible.has(s));
      if (candidates.length === 0) return;
      const next = candidates[Math.floor(Math.random() * candidates.length)];
      const img = thumbs[slot];
      img.style.opacity = '0';
      setTimeout(() => {
        img.setAttribute('src', next);
        current[slot] = next;
        img.style.opacity = '1';
      }, 700);
    }
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      setInterval(swap, 2200);
    }

    // ---- Visor ampliado ----
    let index = 0;
    function srcToIndex(src: string) {
      const m = src.match(/hero-(\d+)\.jpg/);
      return m ? parseInt(m[1], 10) - 1 : 0;
    }
    function show(i: number) {
      index = (i + count) % count;
      lbImg!.src = fullSrc[index];
    }
    function open(i: number) {
      paused = true;
      show(i);
      lightbox!.classList.remove('hidden');
      lightbox!.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      paused = false;
      lightbox!.classList.add('hidden');
      lightbox!.classList.remove('flex');
      document.body.style.overflow = '';
    }

    buttons.forEach((btn, i) => {
      btn.addEventListener('click', () =>
        open(srcToIndex(current[i] || thumbsSrc[i]))
      );
    });

    document.getElementById('lb-close')?.addEventListener('click', close);
    document.getElementById('lb-prev')?.addEventListener('click', (e) => {
      e.stopPropagation();
      show(index - 1);
    });
    document.getElementById('lb-next')?.addEventListener('click', (e) => {
      e.stopPropagation();
      show(index + 1);
    });
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) close();
    });
    document.addEventListener('keydown', (e) => {
      if (lightbox!.classList.contains('hidden')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(index - 1);
      if (e.key === 'ArrowRight') show(index + 1);
    });
  }
</script>
