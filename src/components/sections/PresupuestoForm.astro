---
import Button from '@/components/common/Button.astro';
import { siteConfig } from '@/config/site.config';

interface Props {
  servicio: string; // se guarda en la solicitud y define la solapa del panel
  carpeta: string; // subcarpeta del bucket de adjuntos
  tipoLugarLabel: string;
  tipoLugarOpciones: string[];
  rubroLabel?: string;
  rubroPlaceholder?: string;
  mostrarAmbientes?: boolean;
  mostrarEmpleados?: boolean;
  tipoTrabajoLabel?: string;
  tipoTrabajoMultiple?: boolean;
  tipoTrabajoOpciones: string[];
  potenciaLabel?: string;
  potenciaPlaceholder?: string;
  tramitesLabel?: string;
  tramitesOpciones: string[];
  mostrarPresupuesto?: boolean;
  pisoTrigger?: string; // valor de tipo_propiedad que muestra el campo "piso" (ej: "Departamento")
  mensajePlaceholder: string;
}

const {
  servicio,
  carpeta,
  tipoLugarLabel,
  tipoLugarOpciones,
  rubroLabel,
  rubroPlaceholder = 'Ej: gastronomía, indumentaria, logística…',
  mostrarAmbientes = false,
  mostrarEmpleados = false,
  tipoTrabajoLabel = 'Tipo de trabajo',
  tipoTrabajoMultiple = false,
  tipoTrabajoOpciones,
  potenciaLabel,
  potenciaPlaceholder = 'Ej: 10 kW / no sé',
  tramitesLabel = '¿Necesitás trámites o gestiones?',
  tramitesOpciones,
  mostrarPresupuesto = true,
  pisoTrigger,
  mensajePlaceholder,
} = Astro.props;

const inp =
  'w-full rounded-lg border border-neutral-300 px-4 py-3 text-neutral-900 placeholder:text-neutral-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-200 focus:outline-none transition-colors';
const lbl = 'block text-sm font-medium text-neutral-700 mb-1';
---

<form id="presupuesto-form" class="space-y-6">
  <div>
    <label for="nombre" class={lbl}>Nombre completo *</label>
    <input type="text" id="nombre" name="nombre" required class={inp} placeholder="Tu nombre" />
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="email" class={lbl}>Email *</label>
      <input type="email" id="email" name="email" required class={inp} placeholder="tu@email.com" />
      <p id="email-error" class="hidden text-xs text-red-600 mt-1"></p>
      <p id="email-sugerencia" class="hidden text-xs text-amber-700 mt-1"></p>
    </div>
    <div>
      <label for="telefono" class={lbl}>Teléfono / celular</label>
      <input type="tel" id="telefono" name="telefono" class={inp} placeholder="Ej: 11 6606 0403 o 351 234 5678" />
      <p class="text-xs text-neutral-400 mt-1">Código de área sin el 0 y número sin el 15.</p>
      <p id="telefono-error" class="hidden text-xs text-red-600 mt-1"></p>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="localidad" class={lbl}>Localidad / zona *</label>
      <input type="text" id="localidad" name="localidad" required class={inp} placeholder="Ej: San Miguel, CABA…" />
    </div>
    <div>
      <label for="tipo_propiedad" class={lbl}>{tipoLugarLabel}</label>
      <select id="tipo_propiedad" name="tipo_propiedad" required class={inp}>
        <option value="">Seleccioná…</option>
        {tipoLugarOpciones.map((o) => <option>{o}</option>)}
      </select>
    </div>
  </div>

  {pisoTrigger && (
    <div id="piso-campo" class="hidden" data-piso-trigger={pisoTrigger}>
      <label for="piso" class={lbl}>Piso de la unidad funcional</label>
      <input
        type="text"
        id="piso"
        name="piso"
        inputmode="numeric"
        class={inp}
        placeholder="Ej: 5 (PB = 0)"
      />
      <p id="piso-error" class="hidden text-xs text-red-600 mt-1"></p>
    </div>
  )}

  {rubroLabel && (
    <div>
      <label for="rubro" class={lbl}>{rubroLabel}</label>
      <input type="text" id="rubro" name="rubro" class={inp} placeholder={rubroPlaceholder} />
    </div>
  )}

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div>
      <label for="superficie_m2" class={lbl}>Superficie aproximada (m²)</label>
      <input type="number" id="superficie_m2" name="superficie_m2" min="1" class={inp} placeholder="Ej: 80" />
    </div>
    {mostrarAmbientes ? (
      <div>
        <label for="ambientes" class={lbl}>Cantidad de ambientes</label>
        <input type="number" id="ambientes" name="ambientes" min="1" class={inp} placeholder="Ej: 3" />
      </div>
    ) : (
      <div>
        <label for="tiene_planos" class={lbl}>¿Tenés planos del lugar?</label>
        <select id="tiene_planos" name="tiene_planos" class={inp}>
          <option value="">Seleccioná…</option>
          <option>Sí</option>
          <option>No</option>
        </select>
      </div>
    )}
    {mostrarEmpleados && (
      <div>
        <label for="empleados" class={lbl}>Cantidad de personal del establecimiento</label>
        <input type="number" id="empleados" name="empleados" min="1" class={inp} placeholder="Ej: 15" />
      </div>
    )}
  </div>

  {tipoTrabajoMultiple ? (
    <div>
      <span class={lbl}>{tipoTrabajoLabel} *</span>
      <div class="grid sm:grid-cols-2 gap-2">
        {tipoTrabajoOpciones.map((o) => (
          <label class="flex items-center gap-2.5 text-sm text-neutral-700 border border-neutral-300 rounded-lg px-3 py-2.5 cursor-pointer transition-colors has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50">
            <input type="checkbox" name="tipo_trabajo" value={o} class="accent-primary-600 size-4 shrink-0" />
            {o}
          </label>
        ))}
      </div>
      <p id="tipo-trabajo-error" class="hidden text-xs text-red-600 mt-1">Elegí al menos una opción.</p>
    </div>
  ) : (
    <div>
      <label for="tipo_trabajo" class={lbl}>{tipoTrabajoLabel} *</label>
      <select id="tipo_trabajo" name="tipo_trabajo" required class={inp}>
        <option value="">Seleccioná…</option>
        {tipoTrabajoOpciones.map((o) => <option>{o}</option>)}
      </select>
    </div>
  )}

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    {mostrarAmbientes && (
      <div>
        <label for="tiene_planos" class={lbl}>¿Tenés planos del lugar?</label>
        <select id="tiene_planos" name="tiene_planos" class={inp}>
          <option value="">Seleccioná…</option>
          <option>Sí</option>
          <option>No</option>
        </select>
      </div>
    )}
    <div>
      <label for="tramites" class={lbl}>{tramitesLabel}</label>
      <select id="tramites" name="tramites" class={inp}>
        <option value="">Seleccioná…</option>
        {tramitesOpciones.map((o) => <option>{o}</option>)}
      </select>
    </div>
    {!mostrarAmbientes && potenciaLabel && (
      <div>
        <label for="potencia" class={lbl}>{potenciaLabel}</label>
        <input type="text" id="potencia" name="potencia" class={inp} placeholder={potenciaPlaceholder} />
      </div>
    )}
  </div>

  <div>
    <label for="plazo" class={lbl}>¿Para cuándo lo necesitás?</label>
    <select id="plazo" name="plazo" class={inp}>
      <option value="">Seleccioná…</option>
      <option>Lo antes posible</option>
      <option>En 1 a 3 meses</option>
      <option>En más de 3 meses</option>
      <option>Sin definir</option>
    </select>
  </div>

  {mostrarPresupuesto && (
    <div>
      <label for="presupuesto_estimado" class={lbl}>¿Tenés un presupuesto destinado a este proyecto?</label>
      <p class="text-xs text-neutral-500 mb-2">
        Si tenés un monto pensado, contanoslo acá: nos ayuda a entender y adecuarnos lo mejor posible a tus necesidades y posibilidades.
      </p>
      <input
        type="text"
        id="presupuesto_estimado"
        name="presupuesto_estimado"
        class={inp}
        placeholder="Ej: $2.000.000 aprox. / a definir"
      />
    </div>
  )}

  <div>
    <label for="mensaje" class={lbl}>Contanos tu proyecto *</label>
    <textarea id="mensaje" name="mensaje" required rows={5} class={`${inp} resize-y`} placeholder={mensajePlaceholder}></textarea>
  </div>

  <div>
    <span class={lbl}>Archivos adjuntos (opcional)</span>
    <p class="text-xs text-neutral-500 mb-2">
      Podés sumar de a un archivo: planos (AutoCAD, PDF), fotos o lo que consideres útil para que podamos presupuestar.
      Hasta 5 archivos de 15 MB cada uno.
    </p>
    <ul id="archivos-lista" class="space-y-1.5 mb-2"></ul>
    <label
      id="archivo-boton"
      class="inline-flex items-center gap-2 cursor-pointer text-sm font-medium text-primary-700 border border-primary-300 bg-primary-50 hover:bg-primary-100 rounded-lg px-4 py-2.5 transition-colors"
    >
      + Agregar archivo
      <input
        type="file"
        id="archivo-input"
        class="hidden"
        accept=".pdf,.dwg,.dxf,.jpg,.jpeg,.png,.heic,.zip,.rar,.doc,.docx,.xls,.xlsx"
      />
    </label>
  </div>

  <div>
    <Button type="submit" variant="primary" size="lg" class="w-full">Enviar solicitud</Button>
  </div>

  <div id="form-result" class="hidden text-center py-4 rounded-lg" role="status" aria-live="polite" aria-atomic="true"></div>
</form>

<script
  define:vars={{
    supabaseUrl: siteConfig.integrations.supabase.url,
    supabaseKey: siteConfig.integrations.supabase.anonKey,
    formsKey: siteConfig.integrations.forms.accessKey,
    servicio,
    carpeta,
    tipoTrabajoMultiple,
  }}
>
  const form = document.getElementById('presupuesto-form');
  const result = document.getElementById('form-result');

  // --- Validación de email ---
  const emailInput = document.getElementById('email');
  const emailError = document.getElementById('email-error');
  const emailSugerencia = document.getElementById('email-sugerencia');
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[a-zA-Z]{2,}$/;
  const DOMINIOS = [
    'gmail.com', 'hotmail.com', 'outlook.com', 'yahoo.com', 'yahoo.com.ar',
    'icloud.com', 'live.com', 'hotmail.com.ar', 'outlook.com.ar',
    'mail.com', 'proton.me', 'fibertel.com.ar', 'speedy.com.ar', 'arnet.com.ar',
  ];

  function distancia(a, b) {
    const m = Array.from({ length: a.length + 1 }, (_, i) => [i, ...Array(b.length).fill(0)]);
    for (let j = 0; j <= b.length; j++) m[0][j] = j;
    for (let i = 1; i <= a.length; i++)
      for (let j = 1; j <= b.length; j++)
        m[i][j] = Math.min(m[i - 1][j] + 1, m[i][j - 1] + 1, m[i - 1][j - 1] + (a[i - 1] === b[j - 1] ? 0 : 1));
    return m[a.length][b.length];
  }

  function validarEmail() {
    const valor = emailInput.value.trim().toLowerCase();
    emailError.classList.add('hidden');
    emailSugerencia.classList.add('hidden');
    if (!valor) return false;

    if (!EMAIL_RE.test(valor)) {
      emailError.textContent = 'Revisá el email: tiene que tener la forma nombre@dominio.com';
      emailError.classList.remove('hidden');
      return false;
    }

    const dominio = valor.split('@')[1];
    if (!DOMINIOS.includes(dominio)) {
      const cercano = DOMINIOS.find((d) => distancia(dominio, d) > 0 && distancia(dominio, d) <= 2);
      if (cercano) {
        emailSugerencia.textContent = `¿Quisiste decir @${cercano}? Tocá acá para corregirlo.`;
        emailSugerencia.classList.remove('hidden');
        emailSugerencia.onclick = () => {
          emailInput.value = valor.split('@')[0] + '@' + cercano;
          emailSugerencia.classList.add('hidden');
        };
        emailSugerencia.style.cursor = 'pointer';
      }
    }
    return true;
  }

  emailInput?.addEventListener('blur', validarEmail);
  emailInput?.addEventListener('input', () => {
    emailError.classList.add('hidden');
  });

  // --- Validación de teléfono argentino (10 dígitos: característica + número) ---
  const telInput = document.getElementById('telefono');
  const telError = document.getElementById('telefono-error');

  function normalizarTelefono(valor) {
    let d = valor.replace(/\D/g, '');
    if (d.startsWith('549')) d = d.slice(3);
    else if (d.startsWith('54') && d.length > 10) d = d.slice(2);
    if (d.startsWith('0')) d = d.slice(1);
    if (d.length === 12) {
      for (const corte of [2, 3, 4]) {
        if (d.slice(corte, corte + 2) === '15') {
          d = d.slice(0, corte) + d.slice(corte + 2);
          break;
        }
      }
    }
    return d;
  }

  function validarTelefono() {
    const valor = telInput.value.trim();
    telError.classList.add('hidden');
    if (!valor) return true;
    const d = normalizarTelefono(valor);
    if (d.length === 10) {
      telInput.value = d;
      return true;
    }
    telError.textContent = 'Revisá el número: tienen que ser 10 dígitos en total (código de área sin 0 y número sin 15). Ej: 1166060403';
    telError.classList.remove('hidden');
    return false;
  }

  telInput?.addEventListener('blur', validarTelefono);
  telInput?.addEventListener('input', () => {
    telError.classList.add('hidden');
  });

  // --- Campo "piso" condicional (aparece según tipo de propiedad) ---
  const tipoPropInput = document.getElementById('tipo_propiedad');
  const pisoCampo = document.getElementById('piso-campo');
  const pisoInput = document.getElementById('piso');
  const pisoError = document.getElementById('piso-error');
  const pisoTrigger = pisoCampo?.dataset.pisoTrigger;

  function actualizarPiso() {
    if (!pisoCampo) return;
    const mostrar = tipoPropInput.value === pisoTrigger;
    pisoCampo.classList.toggle('hidden', !mostrar);
    if (!mostrar) {
      pisoInput.value = '';
      pisoError.classList.add('hidden');
    }
  }
  tipoPropInput?.addEventListener('change', actualizarPiso);

  // Solo números en el campo piso
  pisoInput?.addEventListener('input', () => {
    pisoInput.value = pisoInput.value.replace(/\D/g, '');
    pisoError.classList.add('hidden');
  });

  // Devuelve true si podemos seguir; si supera 99 pisos pide confirmación
  function validarPiso() {
    if (!pisoCampo || pisoCampo.classList.contains('hidden')) return true;
    const v = pisoInput.value.trim();
    if (!v) return true; // opcional
    const n = Number(v);
    if (v.length > 2) {
      return confirm(`Ingresaste el piso ${n}. ¿Es correcto? En Argentina es poco común un edificio de más de 99 pisos.`);
    }
    return true;
  }

  // --- Manejo de archivos adjuntos (de a uno, hasta 5) ---
  const MAX_ARCHIVOS = 5;
  const MAX_MB = 15;
  const archivos = [];
  const lista = document.getElementById('archivos-lista');
  const inputArchivo = document.getElementById('archivo-input');
  const botonArchivo = document.getElementById('archivo-boton');

  function dibujarLista() {
    lista.innerHTML = '';
    archivos.forEach((file, i) => {
      const li = document.createElement('li');
      li.className = 'flex items-center gap-2 text-sm text-neutral-700 bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2';
      const nombre = document.createElement('span');
      nombre.className = 'flex-1 min-w-0 truncate';
      nombre.textContent = `${file.name} (${(file.size / 1048576).toFixed(1)} MB)`;
      const quitar = document.createElement('button');
      quitar.type = 'button';
      quitar.textContent = 'Quitar';
      quitar.className = 'text-red-600 text-xs font-medium hover:underline shrink-0';
      quitar.addEventListener('click', () => {
        archivos.splice(i, 1);
        dibujarLista();
      });
      li.appendChild(nombre);
      li.appendChild(quitar);
      lista.appendChild(li);
    });
    botonArchivo.style.display = archivos.length >= MAX_ARCHIVOS ? 'none' : '';
  }

  inputArchivo?.addEventListener('change', () => {
    const file = inputArchivo.files?.[0];
    inputArchivo.value = '';
    if (!file) return;
    if (file.size > MAX_MB * 1048576) {
      alert(`El archivo supera los ${MAX_MB} MB. Comprimilo o mandalo por WhatsApp.`);
      return;
    }
    if (archivos.length >= MAX_ARCHIVOS) return;
    archivos.push(file);
    dibujarLista();
  });

  async function subirArchivos() {
    const base = `${carpeta}/${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
    const rutas = [];
    for (const file of archivos) {
      const limpio = file.name.replace(/[^\w.\-]+/g, '_');
      const ruta = `${base}/${limpio}`;
      const res = await fetch(`${supabaseUrl}/storage/v1/object/solicitudes/${ruta}`, {
        method: 'POST',
        headers: {
          apikey: supabaseKey,
          Authorization: `Bearer ${supabaseKey}`,
          'Content-Type': file.type || 'application/octet-stream',
        },
        body: file,
      });
      if (!res.ok) throw new Error('upload');
      rutas.push(ruta);
    }
    return rutas;
  }

  if (form && result) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!validarEmail()) {
        emailInput.focus();
        return;
      }
      if (!validarTelefono()) {
        telInput.focus();
        return;
      }
      if (!validarPiso()) {
        pisoInput.focus();
        return;
      }
      const submitBtn = form.querySelector('button[type="submit"]');
      const originalText = submitBtn.textContent;
      submitBtn.textContent = 'Enviando...';
      submitBtn.disabled = true;

      const fd = new FormData(form);
      const val = (k) => (fd.get(k) || '').toString().trim() || null;
      const num = (k) => (fd.get(k) ? Number(fd.get(k)) : null);

      // Con casilleros: exigir al menos una opción tildada
      const ttError = document.getElementById('tipo-trabajo-error');
      if (tipoTrabajoMultiple) {
        if (fd.getAll('tipo_trabajo').length === 0) {
          ttError?.classList.remove('hidden');
          ttError?.scrollIntoView({ behavior: 'smooth', block: 'center' });
          submitBtn.textContent = originalText;
          submitBtn.disabled = false;
          return;
        }
        ttError?.classList.add('hidden');
      }

      const solicitud = {
        servicio,
        nombre: val('nombre'),
        email: val('email'),
        telefono: val('telefono'),
        localidad: val('localidad'),
        tipo_propiedad: val('tipo_propiedad'),
        piso: val('piso'),
        rubro: val('rubro'),
        superficie_m2: num('superficie_m2'),
        ambientes: num('ambientes'),
        empleados: num('empleados'),
        tipo_trabajo: tipoTrabajoMultiple ? fd.getAll('tipo_trabajo').join(' · ') : val('tipo_trabajo'),
        tiene_planos: val('tiene_planos'),
        tramites: val('tramites'),
        potencia: val('potencia'),
        plazo: val('plazo'),
        presupuesto_estimado: val('presupuesto_estimado'),
        mensaje: val('mensaje'),
      };

      try {
        if (archivos.length) {
          submitBtn.textContent = 'Subiendo archivos...';
          solicitud.archivos = await subirArchivos();
        }
        submitBtn.textContent = 'Enviando...';
        const res = await fetch(`${supabaseUrl}/rest/v1/solicitudes_presupuesto`, {
          method: 'POST',
          headers: {
            apikey: supabaseKey,
            Authorization: `Bearer ${supabaseKey}`,
            'Content-Type': 'application/json',
            Prefer: 'return=minimal',
          },
          body: JSON.stringify(solicitud),
        });

        if (res.ok) {
          const resumen = Object.entries(solicitud)
            .filter(([, v]) => v != null)
            .map(([k, v]) => `${k}: ${Array.isArray(v) ? v.length + ' archivo(s) adjunto(s) — ver en el panel' : v}`)
            .join('\n');
          fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              access_key: formsKey,
              subject: `Nueva solicitud de presupuesto (${servicio}): ${solicitud.nombre}`,
              from_name: 'Web IntegracionMP',
              message: resumen,
            }),
          }).catch(() => {});

          result.textContent = '¡Solicitud enviada! Ya la recibimos y nos vamos a contactar a la brevedad.';
          result.className = 'block text-center py-4 rounded-lg bg-accent-100 text-accent-700';
          form.reset();
          archivos.length = 0;
          dibujarLista();
        } else {
          result.textContent = 'Hubo un error al enviar la solicitud. Por favor intentá nuevamente.';
          result.className = 'block text-center py-4 rounded-lg bg-red-100 text-red-700';
        }
      } catch {
        result.textContent = 'Error de conexión. Por favor intentá más tarde.';
        result.className = 'block text-center py-4 rounded-lg bg-red-100 text-red-700';
      } finally {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    });
  }
</script>
