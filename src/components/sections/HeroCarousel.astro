---
import { siteConfig } from '@/config/site.config';
import Button from '@/components/common/Button.astro';
---

<section class="relative" aria-label="Presentación principal">
  <div class="relative min-h-screen flex items-center bg-primary-900">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-900/80 via-primary-800/60 to-primary-900/90" />

    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 w-full">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight">
          INTEGRACION MP
        </h1>
        <p class="mt-6 text-xl text-neutral-200 max-w-2xl">
          Soluciones en electricidad, Seguridad e Higiene, obras civiles / comerciales.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <Button href="/#contacto" variant="secondary" size="lg">
            Solicitar Presupuesto
          </Button>
          <Button href="/services" variant="outline" size="lg" class="border-white text-white hover:bg-white/10">
            Nuestros Servicios
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
