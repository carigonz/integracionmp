---
import { siteConfig } from '@/config/site.config';
import Container from '@/components/common/Container.astro';
import Button from '@/components/common/Button.astro';
---

<section class="relative overflow-hidden bg-gradient-to-br from-primary-700 via-primary-800 to-primary-900 py-20 md:py-24">
  <div class="absolute -top-24 -right-24 size-96 rounded-full bg-secondary-400/20 blur-3xl" aria-hidden="true"></div>
  <div class="absolute -bottom-32 -left-24 size-96 rounded-full bg-primary-400/20 blur-3xl" aria-hidden="true"></div>
  <Container class="relative">
    <div class="text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight text-balance">
        ¿Necesitás un electricista profesional?
      </h2>
      <p class="mt-5 text-lg text-primary-100 max-w-2xl mx-auto leading-relaxed">
        Contactanos hoy para tu presupuesto. Respuesta en menos de 24 horas.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/#contacto" variant="secondary" size="lg">
          Solicitar Presupuesto
        </Button>
        {siteConfig.features.whatsappButton && siteConfig.business.whatsapp && (
          <Button
            href={`https://wa.me/${siteConfig.business.whatsapp}`}
            variant="outline"
            size="lg"
            class="border-white text-white hover:bg-white/10"
            target="_blank"
            rel="noopener noreferrer"
          >
            WhatsApp
          </Button>
        )}
      </div>
    </div>
  </Container>
</section>
