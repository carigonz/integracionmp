---
import { siteConfig } from '@/config/site.config';
import Container from '@/components/common/Container.astro';
import Button from '@/components/common/Button.astro';
---

<section class="bg-primary-700 py-16 md:py-20">
  <Container>
    <div class="text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white">
        ¿Necesitás un electricista profesional?
      </h2>
      <p class="mt-4 text-lg text-primary-100 max-w-2xl mx-auto">
        Contactanos hoy para un presupuesto sin cargo. Respuesta en menos de 24 horas.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/contact" variant="secondary" size="lg">
          Solicitar Presupuesto
        </Button>
        {siteConfig.features.whatsappButton && siteConfig.business.whatsapp && (
          <Button
            href={`https://wa.me/${siteConfig.business.whatsapp}`}
            variant="outline"
            size="lg"
            class="border-white text-white hover:bg-white/10"
            target="_blank"
            rel="noopener noreferrer"
          >
            WhatsApp
          </Button>
        )}
      </div>
    </div>
  </Container>
</section>
