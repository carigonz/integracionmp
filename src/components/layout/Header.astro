---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@/config/site.config';
import type { NavItem } from '@/types';
import Container from '@/components/common/Container.astro';
import MobileMenu from '@/components/layout/MobileMenu.astro';
import logo from '@/assets/logo-icon.png';

const { navigation, theme, business, features } = siteConfig;
const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}

function shouldShowItem(item: NavItem): boolean {
  if (item.href === '/blog' && !features.blog) return false;
  if (item.href === '/team' && !features.team) return false;
  return true;
}

const filteredNav = navigation.filter(shouldShowItem);
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-neutral-200">
  <Container>
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 flex-shrink-0">
        <Image
          src={logo}
          alt={business.name}
          height={48}
          class="h-10 lg:h-12 w-auto"
        />
        <span class="flex flex-col leading-tight">
          <span class="font-display font-bold text-lg lg:text-2xl text-neutral-900 tracking-tight">{theme.logoText}</span>
          <span class="hidden sm:block text-[0.6rem] lg:text-xs text-neutral-500 tracking-wide">Electricidad / Obra civil / S&amp;H</span>
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav aria-label="Navegacion principal" class="hidden lg:flex items-center gap-1">
        {filteredNav.map((item) => (
          item.children && item.children.length > 0 ? (
            <div class="relative group">
              <a
                href={item.href}
                class:list={[
                  'inline-flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-lg transition-colors',
                  isActive(item.href)
                    ? 'text-primary-600 bg-primary-50'
                    : 'text-neutral-700 hover:text-primary-600 hover:bg-neutral-50',
                ]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
                <Icon name="lucide:chevron-down" class="size-4 transition-transform group-hover:rotate-180" />
              </a>
              <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="bg-white rounded-xl shadow-lg border border-neutral-200 py-2 min-w-56">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        'block px-4 py-2.5 text-sm transition-colors',
                        isActive(child.href)
                          ? 'text-primary-600 bg-primary-50 font-medium'
                          : 'text-neutral-700 hover:text-primary-600 hover:bg-neutral-50',
                      ]}
                      aria-current={isActive(child.href) ? 'page' : undefined}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                'px-3 py-2 text-sm font-medium rounded-lg transition-colors',
                isActive(item.href)
                  ? 'text-primary-600 bg-primary-50'
                  : 'text-neutral-700 hover:text-primary-600 hover:bg-neutral-50',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          )
        ))}
      </nav>

      <!-- Desktop CTA & Mobile Toggle -->
      <div class="flex items-center gap-3">
        <!-- Solicitar Presupuesto (desktop) -->
        <a
          href="/#contacto"
          class="hidden lg:inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-gradient-to-r from-secondary-500 to-secondary-400 rounded-xl shadow-soft hover:shadow-lift hover:-translate-y-0.5 transition-all duration-200"
        >
          <Icon name="lucide:zap" class="size-4" />
          <span>Solicitar Presupuesto</span>
        </a>

        <!-- WhatsApp CTA (desktop) -->
        <a
          href={`https://wa.me/${business.whatsapp}`}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden lg:inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-gradient-to-r from-[#25D366] to-[#128C7E] rounded-xl shadow-soft hover:shadow-lift hover:-translate-y-0.5 transition-all duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.121 1.532 5.852L.054 23.293a.75.75 0 0 0 .916.916l5.44-1.478A11.952 11.952 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.891 0-3.67-.523-5.188-1.432l-.372-.22-3.868 1.05 1.05-3.868-.22-.372A9.956 9.956 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
          </svg>
          <span>WhatsApp</span>
        </a>

        <!-- Mobile Menu Toggle -->
        <button
          type="button"
          id="mobile-menu-toggle"
          class="lg:hidden inline-flex items-center justify-center p-2 rounded-lg text-neutral-700 hover:bg-neutral-100 transition-colors"
          aria-label="Abrir menu de navegacion"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <Icon name="lucide:menu" class="size-6" />
        </button>
      </div>
    </div>
  </Container>
</header>

<MobileMenu />
