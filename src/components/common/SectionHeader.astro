---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, subtitle, align = 'center' } = Astro.props;

const alignClasses = align === 'center' ? 'text-center mx-auto' : 'text-left';
---

<div class:list={['max-w-3xl mb-12 md:mb-16', alignClasses]}>
  {eyebrow && (
    <p class="text-sm font-semibold uppercase tracking-wider text-primary-600 mb-3">
      {eyebrow}
    </p>
  )}
  <h2 class="text-3xl md:text-4xl font-bold text-neutral-900">
    {title}
  </h2>
  {subtitle && (
    <p class="mt-4 text-lg text-neutral-600">
      {subtitle}
    </p>
  )}
</div>
