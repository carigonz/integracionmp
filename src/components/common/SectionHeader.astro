---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, subtitle, align = 'center' } = Astro.props;

const alignClasses = align === 'center' ? 'text-center mx-auto' : 'text-left';
---

<div class:list={['max-w-3xl mb-12 md:mb-16', alignClasses]}>
  {eyebrow && (
    <span class="inline-block text-xs font-semibold uppercase tracking-wider text-primary-700 bg-primary-50 ring-1 ring-primary-100 rounded-full px-3 py-1 mb-4">
      {eyebrow}
    </span>
  )}
  <h2 class="text-3xl md:text-5xl font-bold text-neutral-900 tracking-tight text-balance">
    {title}
  </h2>
  {subtitle && (
    <p class="mt-5 text-lg text-neutral-600 leading-relaxed">
      {subtitle}
    </p>
  )}
</div>
