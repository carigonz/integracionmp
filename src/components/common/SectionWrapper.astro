---
interface Props {
  id?: string;
  background?: 'default' | 'alt' | 'dark';
  class?: string;
}

const { id, background = 'default', class: className } = Astro.props;

const backgroundClasses: Record<string, string> = {
  default: 'bg-white',
  alt: 'bg-neutral-50',
  dark: 'bg-neutral-900 text-white',
};
---

<section id={id} class:list={['py-16 md:py-24', backgroundClasses[background], className]}>
  <slot />
</section>
