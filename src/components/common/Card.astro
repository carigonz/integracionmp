---
interface Props {
  href?: string;
  class?: string;
}

const { href, class: className } = Astro.props;

const baseClasses =
  'bg-white rounded-2xl shadow-soft border border-neutral-100 overflow-hidden hover:shadow-lift hover:-translate-y-1 transition-all duration-300';
---

{
  href ? (
    <a href={href} class:list={[baseClasses, className]}>
      <slot />
    </a>
  ) : (
    <div class:list={[baseClasses, className]}>
      <slot />
    </div>
  )
}
