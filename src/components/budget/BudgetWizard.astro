---
import prices from '@/data/prices.json';
---

<div id="budget-wizard-root" class="w-full max-w-[400px]"></div>

<style>
  /* Ocultar flechas nativas del input numérico — usamos nuestros propios botones */
  #budget-wizard-root input[type='number']::-webkit-outer-spin-button,
  #budget-wizard-root input[type='number']::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  #budget-wizard-root input[type='number'] {
    -moz-appearance: textfield;
    appearance: textfield;
  }
</style>

<script define:vars={{ prices }}>
(function () {
  // ── Precios desde build-time (inyectados por define:vars) ──────────────
  const P = {};
  Object.entries(prices.items).forEach(function (entry) { P[entry[0]] = entry[1].price; });
  var MARGIN = prices.estimateMargin;
  var WA = prices.whatsapp;

  // ── Estado ─────────────────────────────────────────────────────────────
  var state = {
    step: 0,
    tipoPropiedad: null,
    piso: 1,
    antiguedad: 10,
    ambientes: 2,
    m2: 50,
    trabajos: {
      bocasToma: false,
      bocasLuz: false,
      canalizacion: false,
      tablero: false,
      protector: false,
      falla: false,
      tendidoCable: false,
    },
    cantBocasToma: 1,
    cantBocasLuz: 1,
    metrosCanalizacion: 5,
    tipoCanalizacion: 'superficial',
    termicasAdicionales: 0,
    metrosCable: 5,
    showResult: false,
  };

  // ── Utilidades ─────────────────────────────────────────────────────────
  function fmt(n) {
    return new Intl.NumberFormat('es-AR', {
      style: 'currency', currency: 'ARS', maximumFractionDigits: 0,
    }).format(n);
  }

  function calc() {
    var total = 0;
    var t = state.trabajos;
    if (t.bocasToma)    total += state.cantBocasToma * P.bocaToma;
    if (t.bocasLuz)     total += state.cantBocasLuz * P.bocaLuz;
    if (t.canalizacion) total += state.metrosCanalizacion *
      (state.tipoCanalizacion === 'superficial' ? P.canalizacionSuperficial : P.canalizacionEmbutida);
    if (t.tablero)      total += P.tableroBase + state.termicasAdicionales * P.termicaAdicional;
    if (t.protector)    total += P.protectorTension;
    if (t.falla)        total += P.deteccionFalla;
    if (t.tendidoCable) total += state.metrosCable * P.tendidoCable;
    if (state.tipoPropiedad === 'depto') {
      if (state.antiguedad > 20) total *= 1.15;
      if (state.piso >= 5)       total *= 1.10;
    }
    return total;
  }

  function hasQtyFields() {
    var t = state.trabajos;
    return !!(t.bocasToma || t.bocasLuz || t.canalizacion || t.tablero || t.tendidoCable);
  }

  function resetState() {
    state.step = 0; state.tipoPropiedad = null; state.showResult = false;
    state.piso = 1; state.antiguedad = 10; state.ambientes = 2; state.m2 = 50;
    state.trabajos = { bocasToma: false, bocasLuz: false, canalizacion: false,
                       tablero: false, protector: false, falla: false, tendidoCable: false };
    state.cantBocasToma = 1; state.cantBocasLuz = 1; state.metrosCanalizacion = 5;
    state.tipoCanalizacion = 'superficial'; state.termicasAdicionales = 0; state.metrosCable = 5;
  }

  function canAdvance() {
    if (state.step === 0) return state.tipoPropiedad !== null;
    if (state.step === 2) {
      var vals = Object.values(state.trabajos);
      for (var i = 0; i < vals.length; i++) { if (vals[i]) return true; }
      return false;
    }
    return true;
  }

  function buildWAMsg() {
    var s = state;
    var lines = ['Hola, solicito un presupuesto estimado:'];
    var tipos = { casa: 'Casa', depto: 'Departamento', ph: 'PH' };
    lines.push('Tipo: ' + tipos[s.tipoPropiedad]);
    if (s.tipoPropiedad === 'depto') {
      lines.push('Piso: ' + s.piso + ' | Antigüedad: ' + s.antiguedad + ' años');
    } else {
      lines.push('Ambientes: ' + s.ambientes + ' | m²: ' + s.m2);
    }
    lines.push('Trabajos:');
    if (s.trabajos.bocasToma)    lines.push('- Bocas de toma: ' + s.cantBocasToma);
    if (s.trabajos.bocasLuz)     lines.push('- Bocas de luz: ' + s.cantBocasLuz);
    if (s.trabajos.canalizacion) lines.push('- Canalización ' + s.tipoCanalizacion + ': ' + s.metrosCanalizacion + 'm');
    if (s.trabajos.tablero)      lines.push('- Tablero + ' + s.termicasAdicionales + ' térmicas adicionales');
    if (s.trabajos.protector)    lines.push('- Protector de tensión');
    if (s.trabajos.falla)        lines.push('- Detección de falla');
    if (s.trabajos.tendidoCable) lines.push('- Tendido de cable: ' + s.metrosCable + 'm');
    var total = calc();
    lines.push('Estimado web: ' + fmt(total) + ' - ' + fmt(Math.round(total * (1 + MARGIN))));
    return encodeURIComponent(lines.join('\n'));
  }

  // ── Estilos base ───────────────────────────────────────────────────────
  var CARD = 'background:rgba(10,20,40,0.92);backdrop-filter:blur(20px);border-radius:16px;padding:28px;width:100%;border:1px solid rgba(255,255,255,0.08);position:relative;font-family:Inter,system-ui,sans-serif;box-shadow:0 8px 32px rgba(0,0,0,0.3);';
  var ACCENT_GRAD = 'linear-gradient(135deg,var(--color-secondary-500),var(--color-secondary-700))';
  var BTN_SECONDARY = 'padding:10px;border-radius:8px;background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.6);border:1px solid rgba(255,255,255,0.1);cursor:pointer;font-size:13px;';
  var BTN_COUNTER = 'width:32px;height:32px;border-radius:50%;border:1px solid rgba(255,255,255,0.2);background:rgba(255,255,255,0.06);color:white;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;';

  function optBtnStyle(isSelected) {
    return 'display:flex;align-items:center;gap:12px;width:100%;padding:12px 16px;border-radius:10px;'
      + 'border:2px solid ' + (isSelected ? 'var(--color-secondary-600)' : 'rgba(255,255,255,0.12)') + ';'
      + 'background:' + (isSelected ? 'rgba(184,122,10,0.12)' : 'rgba(255,255,255,0.04)') + ';'
      + 'color:white;cursor:pointer;text-align:left;font-size:14px;font-family:Inter,system-ui,sans-serif;transition:all 0.2s;';
  }

  function chkBtnStyle(isSelected) {
    return 'display:flex;align-items:center;gap:10px;width:100%;padding:10px 14px;border-radius:8px;'
      + 'border:2px solid ' + (isSelected ? 'var(--color-secondary-600)' : 'rgba(255,255,255,0.1)') + ';'
      + 'background:' + (isSelected ? 'rgba(184,122,10,0.1)' : 'transparent') + ';'
      + 'color:white;cursor:pointer;text-align:left;font-size:13px;font-family:Inter,system-ui,sans-serif;transition:all 0.2s;';
  }

  // ── Builders HTML ──────────────────────────────────────────────────────
  function dots() {
    var total = (state.step >= 2 && !hasQtyFields()) ? 3 : 4;
    var curDot = Math.min(state.step, total - 1);
    var html = '<div style="display:flex;gap:6px;justify-content:center;margin-bottom:16px;">';
    for (var i = 0; i < total; i++) {
      var isActive = (i === curDot);
      var isPast   = (i < curDot);
      var bg = isPast   ? 'var(--color-secondary-700)' :
               isActive ? 'var(--color-secondary-500)' : 'rgba(255,255,255,0.2)';
      html += '<div style="width:' + (isActive ? 24 : 8) + 'px;height:8px;border-radius:4px;background:' + bg + ';transition:all 0.3s;"></div>';
    }
    return html + '</div>';
  }

  function optionBtn(icon, label, subtitle, field, value) {
    var sel = state[field] === value;
    return '<button onclick="window.__wiz.set(\'' + field + '\',\'' + value + '\')" style="' + optBtnStyle(sel) + '">'
      + '<span style="font-size:22px">' + icon + '</span>'
      + '<div><div style="font-weight:600">' + label + '</div>'
      + (subtitle ? '<div style="font-size:12px;opacity:0.6;margin-top:2px">' + subtitle + '</div>' : '')
      + '</div></button>';
  }

  function checkBtn(icon, label, key) {
    var sel = state.trabajos[key];
    var chkBg = sel ? 'var(--color-secondary-600)' : 'transparent';
    var chkBorder = sel ? 'none' : '2px solid rgba(255,255,255,0.3)';
    return '<button onclick="window.__wiz.toggle(\'' + key + '\')" style="' + chkBtnStyle(sel) + '">'
      + '<div style="width:20px;height:20px;border-radius:4px;border:' + chkBorder + ';background:' + chkBg + ';'
      + 'display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;">' + (sel ? '✓' : '') + '</div>'
      + '<span>' + icon + ' ' + label + '</span>'
      + '</button>';
  }

  function counter(label, field, min, max, unit) {
    var val = state[field];
    var unitHtml = unit ? '<span style="font-size:11px;font-weight:400;opacity:0.6;margin-left:2px"> ' + unit + '</span>' : '';
    var inputStyle = 'color:white;font-weight:700;font-size:16px;width:44px;text-align:center;'
      + 'background:transparent;border:none;outline:none;-moz-appearance:textfield;appearance:textfield;';
    return '<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.08);">'
      + '<span style="color:white;font-size:14px;">' + label + '</span>'
      + '<div style="display:flex;align-items:center;gap:8px;">'
      + '<button onclick="window.__wiz.inc(\'' + field + '\',-1,' + min + ',' + max + ')" style="' + BTN_COUNTER + '">−</button>'
      + '<input type="number" min="' + min + '" max="' + max + '" value="' + val + '"'
      + ' oninput="window.__wiz.silent(\'' + field + '\',this.value)"'
      + ' onblur="window.__wiz.clamp(\'' + field + '\',' + min + ',' + max + ')"'
      + ' onkeydown="if(event.key===\'Enter\')this.blur()"'
      + ' style="' + inputStyle + '" />'
      + unitHtml
      + '<button onclick="window.__wiz.inc(\'' + field + '\',1,' + min + ',' + max + ')" style="' + BTN_COUNTER + '">+</button>'
      + '</div></div>';
  }

  function step0() {
    return '<p style="color:rgba(255,255,255,0.7);font-size:14px;margin-bottom:12px">¿Qué tipo de propiedad es?</p>'
      + '<div style="display:flex;flex-direction:column;gap:8px">'
      + optionBtn('🏠', 'Casa', 'Vivienda particular', 'tipoPropiedad', 'casa')
      + optionBtn('🏢', 'Departamento', 'En edificio', 'tipoPropiedad', 'depto')
      + optionBtn('🏘️', 'PH', 'Propiedad horizontal', 'tipoPropiedad', 'ph')
      + '</div>';
  }

  function step1() {
    var isDepto = state.tipoPropiedad === 'depto';
    var html = '<p style="color:rgba(255,255,255,0.7);font-size:14px;margin-bottom:12px">Contanos sobre la propiedad</p>';
    if (isDepto) {
      html += counter('Piso', 'piso', 1, 30, '');
      html += counter('Antigüedad del edificio', 'antiguedad', 0, 100, 'años');
      html += counter('Ambientes', 'ambientes', 1, 10, '');
    } else {
      html += counter('Ambientes', 'ambientes', 1, 15, '');
      html += counter('Superficie aprox.', 'm2', 10, 500, 'm²');
    }
    return html;
  }

  function step2() {
    return '<p style="color:rgba(255,255,255,0.7);font-size:14px;margin-bottom:12px">¿Qué trabajos necesitás?</p>'
      + '<div style="display:flex;flex-direction:column;gap:6px">'
      + checkBtn('🔌', 'Cambio de bocas de toma', 'bocasToma')
      + checkBtn('💡', 'Bocas de luz', 'bocasLuz')
      + checkBtn('🔧', 'Canalización eléctrica', 'canalizacion')
      + checkBtn('📦', 'Cambio de tablero', 'tablero')
      + checkBtn('🛡️', 'Protector de tensión', 'protector')
      + checkBtn('🔍', 'Detección de falla', 'falla')
      + checkBtn('🔌', 'Tendido de cable principal', 'tendidoCable')
      + '</div>';
  }

  function step3() {
    var t = state.trabajos;
    var hasQty = t.bocasToma || t.bocasLuz || t.canalizacion || t.tablero || t.tendidoCable;
    var html = '<p style="color:rgba(255,255,255,0.7);font-size:14px;margin-bottom:12px">Definí las cantidades</p>';
    if (t.bocasToma)    html += counter('Bocas de toma', 'cantBocasToma', 1, 30, '');
    if (t.bocasLuz)     html += counter('Bocas de luz', 'cantBocasLuz', 1, 30, '');
    if (t.canalizacion) {
      html += counter('Metros de canalización', 'metrosCanalizacion', 1, 100, 'm');
      html += '<div style="margin-top:8px;display:flex;gap:8px">'
        + optionBtn('📐', 'Superficial', '', 'tipoCanalizacion', 'superficial')
        + optionBtn('🧱', 'Embutida', '', 'tipoCanalizacion', 'embutida')
        + '</div>';
    }
    if (t.tablero)      html += counter('Térmicas adicionales', 'termicasAdicionales', 0, 10, '');
    if (t.tendidoCable) html += counter('Metros de cable', 'metrosCable', 1, 100, 'm');
    if (!hasQty) {
      html += '<p style="color:rgba(255,255,255,0.5);font-size:13px;text-align:center;padding:20px 0">'
        + 'Los servicios seleccionados tienen precio fijo. Continuá para ver el estimado.</p>';
    }
    return html;
  }

  function resultScreen() {
    var total = calc();
    var max = Math.round(total * (1 + MARGIN));
    var s = state;
    var t = s.trabajos;

    function row(label, amount) {
      return '<div style="display:flex;justify-content:space-between;color:rgba(255,255,255,0.7);font-size:13px;padding:4px 0">'
        + '<span>' + label + '</span><span>' + fmt(amount) + '</span></div>';
    }

    var desglose = '';
    if (t.bocasToma)    desglose += row('Bocas de toma ×' + s.cantBocasToma, s.cantBocasToma * P.bocaToma);
    if (t.bocasLuz)     desglose += row('Bocas de luz ×' + s.cantBocasLuz, s.cantBocasLuz * P.bocaLuz);
    if (t.canalizacion) desglose += row(
      'Canalización ' + s.tipoCanalizacion + ' ' + s.metrosCanalizacion + 'm',
      s.metrosCanalizacion * (s.tipoCanalizacion === 'superficial' ? P.canalizacionSuperficial : P.canalizacionEmbutida));
    if (t.tablero)      desglose += row(
      'Tablero' + (s.termicasAdicionales > 0 ? ' +' + s.termicasAdicionales + ' térm.' : ''),
      P.tableroBase + s.termicasAdicionales * P.termicaAdicional);
    if (t.protector)    desglose += row('Protector de tensión', P.protectorTension);
    if (t.falla)        desglose += row('Detección de falla', P.deteccionFalla);
    if (t.tendidoCable) desglose += row('Tendido cable ' + s.metrosCable + 'm', s.metrosCable * P.tendidoCable);
    if (s.tipoPropiedad === 'depto' && (s.antiguedad > 20 || s.piso >= 5)) {
      desglose += '<div style="display:flex;justify-content:space-between;color:rgba(255,200,100,0.7);font-size:12px;padding:6px 0;border-top:1px solid rgba(255,255,255,0.06);margin-top:4px">'
        + '<span>Recargo ' + (s.antiguedad > 20 ? '(+15% antigüedad) ' : '') + (s.piso >= 5 ? '(+10% piso alto)' : '') + '</span>'
        + '<span>incluido</span></div>';
    }

    return '<div style="text-align:center;margin-bottom:20px">'
      + '<div style="font-size:40px;margin-bottom:8px">⚡</div>'
      + '<h3 style="color:white;font-size:18px;font-weight:700;font-family:Poppins,system-ui,sans-serif;margin:0">Estimación aproximada</h3>'
      + '<p style="color:rgba(255,255,255,0.5);font-size:12px;margin-top:4px">Sujeto a visita técnica</p>'
      + '</div>'
      + '<div style="background:linear-gradient(135deg,rgba(184,122,10,0.15),rgba(184,122,10,0.05));border-radius:12px;padding:20px 16px;text-align:center;border:1px solid rgba(184,122,10,0.25);margin-bottom:16px">'
      + '<div style="color:rgba(255,255,255,0.6);font-size:12px;margin-bottom:6px">Rango estimado</div>'
      + '<div style="color:var(--color-secondary-500);font-size:28px;font-weight:800;font-family:Poppins,system-ui,sans-serif">' + fmt(total) + '</div>'
      + '<div style="color:rgba(255,255,255,0.4);font-size:13px;margin:4px 0">a</div>'
      + '<div style="color:var(--color-secondary-500);font-size:28px;font-weight:800;font-family:Poppins,system-ui,sans-serif">' + fmt(max) + '</div>'
      + '</div>'
      + '<div style="margin-bottom:20px">'
      + '<div style="color:rgba(255,255,255,0.4);font-size:11px;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px">Desglose</div>'
      + desglose
      + '</div>'
      + '<p style="color:rgba(255,255,255,0.4);font-size:11px;text-align:center;margin:0 0 16px;line-height:1.5">Este es un estimado orientativo. El presupuesto final se define con una visita técnica.</p>'
      + '<div style="display:flex;flex-direction:column;gap:8px">'
      + '<a href="https://wa.me/' + WA + '?text=' + buildWAMsg() + '" target="_blank" rel="noopener noreferrer"'
      + ' style="display:flex;align-items:center;justify-content:center;gap:8px;padding:12px 20px;border-radius:10px;background:#25D366;color:white;font-weight:700;font-size:14px;text-decoration:none;">📱 Enviar por WhatsApp</a>'
      + '<button onclick="window.location.href=\'/cotizar\'" style="padding:12px 20px;border-radius:10px;background:' + ACCENT_GRAD + ';color:white;font-weight:700;font-size:14px;cursor:pointer;border:none;">📋 Presupuesto detallado</button>'
      + '<p style="color:rgba(255,255,255,0.35);font-size:11px;text-align:center;margin:0 0 8px">Podés ajustar los datos y recalcular</p>'
      + '<div style="display:flex;gap:8px">'
      + '<button onclick="window.__wiz.back()" style="flex:1;' + BTN_SECONDARY + '">✏️ Modificar</button>'
      + '<button onclick="window.__wiz.reset()" style="flex:1;' + BTN_SECONDARY + '">Reiniciar</button>'
      + '</div></div>';
  }

  // ── Render principal ───────────────────────────────────────────────────
  function render() {
    var root = document.getElementById('budget-wizard-root');
    if (!root) return;

    var advance = canAdvance();
    var isLast = state.step === 3;
    var body = '';

    if (state.showResult) {
      body = resultScreen();
    } else {
      var stepFns = [step0, step1, step2, step3];
      var nextBtnStyle = 'flex:1;padding:12px 20px;border-radius:10px;background:'
        + (advance ? ACCENT_GRAD : 'rgba(255,255,255,0.06)') + ';color:'
        + (advance ? 'white' : 'rgba(255,255,255,0.3)') + ';border:none;font-weight:700;font-size:14px;cursor:'
        + (advance ? 'pointer' : 'default') + ';transition:all 0.2s;';

      body = '<div style="margin-bottom:16px">'
        + '<h3 style="color:white;font-size:16px;font-weight:700;margin:0 0 4px;font-family:Poppins,system-ui,sans-serif;">⚡ Presupuesto rápido</h3>'
        + '<p style="color:rgba(255,255,255,0.45);font-size:12px;margin:0">Estimá el costo de tu proyecto en segundos</p>'
        + '</div>'
        + dots()
        + stepFns[state.step]()
        + '<div style="display:flex;gap:8px;margin-top:20px">'
        + (state.step > 0
          ? '<button onclick="window.__wiz.back()" style="flex:0 0 auto;padding:12px 16px;border-radius:10px;background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.6);border:1px solid rgba(255,255,255,0.1);cursor:pointer;font-size:14px;">←</button>'
          : '')
        + '<button onclick="window.__wiz.next()" ' + (!advance ? 'disabled' : '') + ' style="' + nextBtnStyle + '">'
        + (isLast ? 'Ver estimado' : 'Siguiente →')
        + '</button></div>';
    }

    root.innerHTML = '<div style="' + CARD + '">'
      + body
      + '<button onclick="window.__wiz.minimize()" aria-label="Minimizar" style="position:absolute;top:10px;right:10px;background:transparent;border:none;color:rgba(255,255,255,0.3);cursor:pointer;font-size:20px;line-height:1;padding:4px 8px;">×</button>'
      + '</div>';
  }

  // ── API global ─────────────────────────────────────────────────────────
  window.__wiz = {
    next: function () {
      if (!canAdvance()) return;
      if (state.step === 2 && !hasQtyFields()) {
        state.showResult = true;
      } else if (state.step < 3) {
        state.step++;
      } else {
        state.showResult = true;
      }
      render();
    },
    back: function () {
      if (state.showResult) { state.showResult = false; } else if (state.step > 0) { state.step--; }
      render();
    },
    reset: function () { resetState(); render(); },
    minimize: function () {
      if (!state.showResult) resetState();
      var root = document.getElementById('budget-wizard-root');
      if (root) root.style.display = 'none';
      document.dispatchEvent(new CustomEvent('budget-wizard-minimize'));
    },
    set: function (field, value) { state[field] = value; render(); },
    setField: function (field, value) { state[field] = value; render(); },
    toggle: function (key) { state.trabajos[key] = !state.trabajos[key]; render(); },
    // Counter helpers: silent update (no re-render) + clamp on blur + inc/dec
    silent: function (field, value) {
      var v = parseInt(value, 10);
      if (!isNaN(v)) state[field] = v;
    },
    clamp: function (field, min, max) {
      var v = parseInt(state[field], 10);
      if (isNaN(v) || v < min) v = min;
      if (v > max) v = max;
      state[field] = v;
      render();
    },
    inc: function (field, step, min, max) {
      var v = parseInt(state[field], 10) || 0;
      state[field] = Math.min(max, Math.max(min, v + step));
      render();
    },
  };

  // ── Init ───────────────────────────────────────────────────────────────
  document.addEventListener('budget-wizard-restore', function () {
    var root = document.getElementById('budget-wizard-root');
    if (root) root.style.display = '';
    render();
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', render);
  } else {
    render();
  }
})();
</script>
