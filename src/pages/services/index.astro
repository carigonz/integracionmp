---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/common/Container.astro';
import SectionWrapper from '@/components/common/SectionWrapper.astro';
import ServiceCard from '@/components/blocks/ServiceCard.astro';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<PageLayout
  title="Nuestros Servicios"
  description="Servicios eléctricos integrales: residencial, comercial, edificios, seguridad e higiene y asesoría de construcción en Buenos Aires."
  subtitle="Soluciones eléctricas para cada necesidad"
>
  <SectionWrapper>
    <Container>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service) => (
          <ServiceCard
            title={service.data.title}
            excerpt={service.data.excerpt}
            icon={service.data.icon}
            href={`/services/${service.id}`}
          />
        ))}
      </div>
    </Container>
  </SectionWrapper>
</PageLayout>
