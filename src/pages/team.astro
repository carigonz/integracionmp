---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/common/Container.astro';
import SectionWrapper from '@/components/common/SectionWrapper.astro';
import TeamMemberCard from '@/components/blocks/TeamMemberCard.astro';

const teamEntries = await getCollection('team');
const members = (teamEntries[0]?.data.items ?? []).sort(
  (a, b) => a.order - b.order
);
---

<PageLayout
  title="Nuestro Equipo"
  description="Conocé al equipo de profesionales de ElectriPro. Electricistas matriculados con experiencia en instalaciones residenciales, comerciales y de edificios."
  subtitle="Profesionales matriculados a tu servicio"
>
  <SectionWrapper>
    <Container>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {members.map((member) => (
          <TeamMemberCard
            name={member.name}
            role={member.role}
            bio={member.bio}
            email={member.email}
            certifications={member.certifications}
          />
        ))}
      </div>
    </Container>
  </SectionWrapper>
</PageLayout>
