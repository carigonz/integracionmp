---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/common/Container.astro';
import Button from '@/components/common/Button.astro';
---

<BaseLayout title="Página no encontrada" description="La página que buscás no existe o fue movida." noindex>
  <main id="main-content" class="flex-1 flex items-center">
    <Container class="py-24 text-center">
      <div class="text-8xl font-bold text-primary-100">404</div>
      <h1 class="text-3xl font-bold text-neutral-900 mt-6">Página no encontrada</h1>
      <p class="text-lg text-neutral-600 mt-4 max-w-md mx-auto">
        La página que estás buscando no existe o fue movida. Verificá la URL o volvé al inicio.
      </p>
      <div class="mt-8">
        <Button href="/" variant="primary" size="lg">
          Volver al inicio
        </Button>
      </div>
    </Container>
  </main>
</BaseLayout>
