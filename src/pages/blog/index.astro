---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/common/Container.astro';
import SectionWrapper from '@/components/common/SectionWrapper.astro';
import BlogPostCard from '@/components/blocks/BlogPostCard.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<PageLayout
  title="Blog"
  description="Artículos, consejos y novedades sobre electricidad, seguridad eléctrica e instalaciones. Mantenete informado con IntegracionMP."
  subtitle="Consejos y novedades del mundo eléctrico"
>
  <SectionWrapper>
    <Container>
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <BlogPostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              href={`/blog/${post.id}`}
            />
          ))}
        </div>
      ) : (
        <p class="text-center text-neutral-500 text-lg">
          Próximamente publicaremos artículos. ¡Volvé pronto!
        </p>
      )}
    </Container>
  </SectionWrapper>
</PageLayout>
