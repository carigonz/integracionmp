---
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/common/Container.astro';
import SectionWrapper from '@/components/common/SectionWrapper.astro';
import SectionHeader from '@/components/common/SectionHeader.astro';
import TeamMemberCard from '@/components/blocks/TeamMemberCard.astro';
import { siteConfig } from '@/config/site.config';

const teamEntries = await getCollection('team');
const members = (teamEntries[0]?.data.items ?? []).sort((a, b) => a.order - b.order);
---

<PageLayout
  title="Nosotros"
  description="Conocé la historia, misión y valores de IntegracionMP. Soluciones en electricidad, Seguridad e Higiene y obras civiles en Gran Buenos Aires."
  subtitle="Profesionales comprometidos con la excelencia"
>
  <SectionWrapper>
    <Container class="max-w-4xl">
      <div class="prose prose-lg max-w-none">
        <h2>Nuestra Historia</h2>
        <p>
          Desde {siteConfig.business.foundedYear}, <strong>{siteConfig.business.name}</strong> se dedica a brindar
          soluciones eléctricas integrales para viviendas, comercios e industria en Buenos Aires
          y alrededores. Lo que comenzó como un pequeño emprendimiento familiar ha ido evolucionando,
          con el objetivo de formar una empresa comprometida y responsable.
        </p>

        <h2>Nuestra Misión</h2>
        <p>
          Proveer servicios eléctricos apuntando siempre a la calidad, priorizando la seguridad
          de las personas y el cumplimiento de las normativas vigentes. Creemos que cada
          instalación eléctrica debe ser segura, eficiente y duradera. Trabajamos de cara
          al cliente, con la mayor de las responsabilidades y transparencia.
        </p>

        <h2>Nuestros Valores</h2>
        <ul>
          <li><strong>Seguridad:</strong> Es nuestra prioridad en cada proyecto</li>
          <li><strong>Profesionalismo:</strong> Equipo en constante capacitación y formación</li>
          <li><strong>Transparencia:</strong> Presupuestos claros y detallados, sin sorpresas</li>
          <li><strong>Compromiso:</strong> Cumplimos con la calidad y garantizamos nuestros trabajos</li>
          <li><strong>Calidad:</strong> Brindamos asesoramiento para que el cliente conozca y decida sobre la elección de los materiales</li>
        </ul>

        <p><strong>Brindamos transparencia y responsabilidad.</strong></p>

        <h2>¿Por qué elegirnos?</h2>
        <p>
          Contamos con un equipo de profesionales matriculados, garantía escrita en
          todos nuestros trabajos y la confianza de más
          de 800 clientes satisfechos. Trabajamos bajo las normas de la Asociación
          Electrotécnica Argentina (AEA) y las reglamentaciones vigentes.
        </p>
      </div>
    </Container>
  </SectionWrapper>

  <SectionWrapper background="alt">
    <Container>
      <SectionHeader
        eyebrow="El Equipo"
        title="Profesionales a tu servicio"
        subtitle="Electricistas y técnicos matriculados con experiencia en instalaciones residenciales, comerciales e industriales."
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mt-12">
        {members.map((member) => (
          <TeamMemberCard
            name={member.name}
            role={member.role}
            bio={member.bio}
            email={member.email}
            certifications={member.certifications}
          />
        ))}
      </div>
    </Container>
  </SectionWrapper>
</PageLayout>
