---
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/common/Container.astro';
import SectionWrapper from '@/components/common/SectionWrapper.astro';
import PresupuestoForm from '@/components/sections/PresupuestoForm.astro';
---

<PageLayout
  title="Presupuesto de Instalación Residencial"
  description="Solicitá un presupuesto detallado para tu instalación eléctrica residencial. Contanos tu proyecto y te asesoramos de forma personalizada."
  subtitle="Contanos tu idea o proyecto con el mayor detalle posible, así te brindamos un asesoramiento personalizado."
>
  <SectionWrapper>
    <Container class="max-w-2xl">
      <PresupuestoForm
        servicio="Electricidad Residencial"
        carpeta="residencial"
        tipoLugarLabel="Tipo de propiedad *"
        tipoLugarOpciones={['Departamento', 'Casa', 'PH', 'Otro']}
        mostrarAmbientes
        tipoTrabajoOpciones={[
          'Instalación nueva (de cero, con proyecto)',
          'Readecuación integral de instalación existente',
          'Ampliación de instalación',
          'Reparación puntual',
        ]}
        tramitesLabel="¿Necesitás trámites con la distribuidora?"
        tramitesOpciones={['Medidor nuevo', 'Aumento de potencia', 'Ninguno', 'No sé']}
        mensajePlaceholder="Describí tu idea o proyecto: estado actual de la instalación, qué querés hacer, detalles del lugar…"
      />
    </Container>
  </SectionWrapper>
</PageLayout>
