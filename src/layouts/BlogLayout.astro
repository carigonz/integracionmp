---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SchemaOrg from '@/components/seo/SchemaOrg.astro';
import { buildBlogPostingSchema } from '@/components/seo/schemas/blogPosting';
import { siteConfig } from '@/config/site.config';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
}

const { title, description, pubDate, updatedDate, author, tags } = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('es-AR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('es-AR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const postUrl = `${siteConfig.site.url}${Astro.url.pathname}`;

const blogPostingSchema = buildBlogPostingSchema({
  title,
  description,
  pubDate,
  updatedDate,
  author,
  url: postUrl,
});
---

<BaseLayout title={title} description={description}>
  <SchemaOrg slot="head" schema={blogPostingSchema} />

  <main id="main-content">
    <article class="py-12 md:py-20">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Article Header -->
        <header class="mb-10">
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-neutral-900 leading-tight">
            {title}
          </h1>

          <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-neutral-500">
            <span class="font-medium text-neutral-700">{author}</span>
            <span aria-hidden="true">&middot;</span>
            <time datetime={pubDate.toISOString()}>
              {formattedPubDate}
            </time>
            {formattedUpdatedDate && (
              <>
                <span aria-hidden="true">&middot;</span>
                <span>
                  Actualizado: <time datetime={updatedDate!.toISOString()}>{formattedUpdatedDate}</time>
                </span>
              </>
            )}
          </div>

          {tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-primary-50 text-primary-700">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </header>

        <!-- Article Content -->
        <div class="prose prose-lg max-w-none prose-headings:text-neutral-900 prose-a:text-primary-600 hover:prose-a:text-primary-700">
          <slot />
        </div>

        <!-- Article Footer -->
        <footer class="mt-12 pt-8 border-t border-neutral-200">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div class="text-sm text-neutral-500">
              Escrito por <span class="font-medium text-neutral-700">{author}</span>
            </div>
            <a
              href="/blog"
              class="inline-flex items-center text-sm font-medium text-primary-600 hover:text-primary-700 transition-colors"
            >
              &larr; Volver al blog
            </a>
          </div>
        </footer>
      </div>
    </article>
  </main>
</BaseLayout>
