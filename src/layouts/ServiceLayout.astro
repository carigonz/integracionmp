---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/config/site.config';

interface Props {
  title: string;
  description: string;
  excerpt: string;
}

const { title, description, excerpt } = Astro.props;

const allServices = await getCollection('services');
const currentSlug = Astro.url.pathname.replace(/^\/services\//, '').replace(/\/$/, '');
const otherServices = allServices
  .filter((service) => service.id !== currentSlug)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---

<BaseLayout title={title} description={description}>
  <main id="main-content">
    <!-- Service Header -->
    <section class="bg-primary-700 py-16 md:py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white">
          {title}
        </h1>
        <p class="mt-4 text-lg md:text-xl text-primary-100 max-w-2xl mx-auto">
          {excerpt}
        </p>
      </div>
    </section>

    <!-- Two-column layout -->
    <section class="py-12 md:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
          <!-- Main content area -->
          <div class="lg:col-span-2 prose prose-lg max-w-none">
            <slot />
          </div>

          <!-- Sidebar -->
          <aside class="lg:col-span-1">
            <div class="sticky top-8 space-y-8">
              <!-- Other Services -->
              <div class="bg-neutral-50 rounded-2xl p-6">
                <h2 class="text-lg font-semibold text-neutral-900 mb-4">
                  Otros servicios
                </h2>
                <nav>
                  <ul class="space-y-2">
                    {otherServices.map((service) => (
                      <li>
                        <a
                          href={`/services/${service.id}`}
                          class="block px-4 py-2 text-neutral-700 hover:bg-primary-50 hover:text-primary-700 rounded-lg transition-colors"
                        >
                          {service.data.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </nav>
              </div>

              <!-- Contact CTA in sidebar -->
              <div class="bg-primary-50 rounded-2xl p-6 text-center">
                <h3 class="text-lg font-semibold text-primary-900 mb-2">
                  Necesitas este servicio?
                </h3>
                <p class="text-sm text-primary-700 mb-4">
                  Contactanos para un presupuesto sin compromiso.
                </p>
                <a
                  href="/contact"
                  class="inline-block w-full px-6 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors text-center"
                >
                  Solicitar presupuesto
                </a>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-primary-700 py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
          Listo para comenzar tu proyecto?
        </h2>
        <p class="text-lg text-primary-100 mb-8 max-w-2xl mx-auto">
          Nuestro equipo de profesionales matriculados esta listo para ayudarte. Contactanos hoy para una consulta gratuita.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-8 py-3 bg-white text-primary-700 font-semibold rounded-lg hover:bg-primary-50 transition-colors"
          >
            Contactanos
          </a>
          <a
            href={`https://wa.me/${siteConfig.business.whatsapp}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors"
          >
            WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
