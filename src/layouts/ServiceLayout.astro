---
import { Icon } from 'astro-icon/components';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/config/site.config';
import ServiceMediaCarousel from '@/components/sections/ServiceMediaCarousel.astro';

interface Props {
  title: string;
  description: string;
  excerpt: string;
  sideImage?: string;
  gallery?: string[];
  emoji?: string;
  comingSoon?: boolean;
  ctaLabel?: string;
  ctaText?: string;
  ctaHref?: string;
  theme?: 'azul' | 'verde';
}

const {
  title,
  description,
  excerpt,
  sideImage,
  gallery,
  emoji,
  comingSoon,
  ctaLabel = 'Solicitar presupuesto',
  ctaText = 'Contactanos para solicitar tu presupuesto.',
  ctaHref = '/#contacto',
  theme = 'azul',
} = Astro.props;

// Tema de color de la sección: azul (eléctrico, default) o verde (Seguridad e Higiene)
const verde = theme === 'verde';
const heroBg = verde ? 'bg-gradient-to-br from-accent-700 to-accent-900' : 'bg-primary-700';
const claro = verde ? 'text-accent-100' : 'text-primary-100';
const ctaBg = verde ? 'bg-accent-800' : 'bg-primary-700';
const botonContacto = verde ? 'text-accent-800 hover:bg-accent-50' : 'text-primary-700 hover:bg-primary-50';
---

<BaseLayout title={title} description={description}>
  <main id="main-content">
    <!-- Service Header -->
    <section class={`${heroBg} py-8 md:py-12`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
          <!-- Titulo (a la izquierda en desktop) -->
          <div class="lg:order-1 text-center lg:text-left">
            <div class="flex items-center justify-center lg:justify-start gap-3">
              <h1 class:list={['text-3xl md:text-4xl lg:text-5xl font-bold text-white', emoji ? 'w-min' : '']}>
                {title}
              </h1>
              {emoji && (
                <span class="text-6xl lg:text-8xl leading-none shrink-0" aria-hidden="true">{emoji}</span>
              )}
            </div>
            <p class={`mt-4 text-lg md:text-xl ${claro} max-w-2xl mx-auto lg:mx-0 lg:text-justify`}>
              {excerpt}
            </p>
          </div>

          <!-- Cuadro de presupuesto (vidrio azul translucido) -->
          <div class="lg:order-2 bg-white/10 backdrop-blur-sm ring-1 ring-white/20 rounded-2xl p-6 md:p-8 shadow-lift w-full max-w-md mx-auto lg:ml-auto lg:mr-0">
            <h3 class="text-2xl md:text-3xl font-extrabold text-secondary-400 uppercase tracking-wide mb-3">
              Presupuesto Personalizado
            </h3>
            <p class={`text-sm ${claro} mb-5`}>
              {ctaText}
            </p>
            <a
              href={ctaHref}
              class="inline-flex items-center justify-center w-full px-6 py-3 bg-gradient-to-r from-secondary-500 to-secondary-400 text-white font-semibold rounded-xl shadow-soft hover:shadow-lift hover:-translate-y-0.5 transition-all duration-200"
            >
              {ctaLabel}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Contenido -->
    {comingSoon ? (
      <section class="py-20 md:py-28">
        <div class="max-w-xl mx-auto px-4 sm:px-6 text-center">
          <div class="inline-flex items-center justify-center size-20 rounded-2xl bg-secondary-100 text-secondary-600 mb-6 shadow-soft">
            <Icon name="lucide:construction" class="size-10" />
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-neutral-900 tracking-tight">
            Sección en construcción
          </h2>
          <p class="mt-4 text-lg text-neutral-600 leading-relaxed">
            Estamos preparando el contenido de este servicio. ¡Próximamente disponible!
          </p>
          <p class="mt-2 text-neutral-500">
            Mientras tanto, escribinos y te asesoramos.
          </p>
        </div>
      </section>
    ) : (
      <section class="py-12 md:py-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="lg:flex lg:items-start lg:gap-12">
            <!-- Texto (izquierda, alineado con el titulo) -->
            <div class="min-[1640px]:relative lg:flex-1">
              {sideImage && (
                <!-- Imagen de referencia: arriba en pantallas chicas, al margen izquierdo en anchas -->
                <img
                  src={sideImage}
                  alt={`Referencia normativa - ${title}`}
                  class="w-28 sm:w-36 mb-6 rounded-lg shadow-soft ring-1 ring-neutral-200 min-[1640px]:absolute min-[1640px]:top-0 min-[1640px]:right-full min-[1640px]:mr-10 min-[1640px]:mb-0 min-[1640px]:w-44"
                />
              )}
              <div class={`prose prose-lg text-justify ${gallery && gallery.length > 0 ? 'max-w-3xl' : 'max-w-none'}`}>
                <slot />
              </div>
            </div>

            <!-- Carrusel de fotos/videos a la derecha -->
            {gallery && gallery.length > 0 && (
              <div class="mt-12 lg:mt-0 w-full max-w-sm mx-auto lg:mx-0 lg:w-80 xl:w-96 shrink-0">
                <ServiceMediaCarousel media={gallery} />
              </div>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- CTA Section -->
    <section class={`${ctaBg} py-16`}>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
          Consultanos tus dudas, estamos para ayudarte
        </h2>
        <p class={`text-lg ${claro} mb-8 max-w-2xl mx-auto`}>
          Escribinos por el formulario o por WhatsApp y te respondemos a la brevedad.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/#contacto"
            class={`inline-flex items-center justify-center px-8 py-3 bg-white ${botonContacto} font-semibold rounded-lg transition-colors`}
          >
            Contactanos
          </a>
          <a
            href={`https://wa.me/${siteConfig.business.whatsapp}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors"
          >
            WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
